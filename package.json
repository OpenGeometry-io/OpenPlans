{
  "name": "@opengeometry/openplans",
  "version": "0.0.21",
  "author": "Vishwajeet Mane",
  "description": "Create 2D Drawings with OpenPlans",
  "main": "./index.js",
  "type": "module",
  "types": "./types/",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "vite",
    "clean": "rimraf dist",
    "build-examples": "vite build",
    "build": "npm run clean && rollup -c",
    "cpy-pkg-json": "cp package.json dist/package.json && cp README.md dist/README.md",
    "pre-prepare": "npm run build && npm run cpy-pkg-json",
    "release": "npm run pre-prepare && cd dist && npm publish",
    "generate-thumbnails": "node scripts/generate-thumbnails.js"
  },
  "keywords": [
    "openplans",
    "opengeometry",
    "architecture",
    "design",
    "cad",
    "geometry"
  ],
  "license": "MIT",
  "dependencies": {
    "@opengeometry/openglyph": "^0.0.7",
    "@types/blob-stream": "^0.1.33",
    "@types/jspdf": "^1.3.3",
    "@types/pdfkit": "^0.17.4",
    "blob-stream": "^0.1.3",
    "jspdf": "^4.0.0",
    "pdfkit": "^0.17.2"
  },
  "peerDependencies": {
    "@types/three": "^0.168.0",
    "camera-controls": "^2.9.0",
    "lil-gui": "^0.19.2",
    "three": "^0.168.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.2",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.2",
    "@types/dat.gui": "^0.7.7",
    "@types/three": "^0.173.0",
    "glob": "^13.0.1",
    "puppeteer": "^24.36.1",
    "rimraf": "^6.0.1",
    "rollup": "^4.34.8",
    "stats.js": "^0.17.0",
    "tslib": "^2.8.1",
    "vite": "^5.4.7"
  },
  "publishConfig": {
    "directory": "dist"
  }
}
